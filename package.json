{
  "name": "@ankh-studio/ai-enablement",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "ai-enablement": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target=node",
    "build:binary": "bun build --compile --minify src/index.ts --outfile dist/ai-enablement",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/cli/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "bunx --bun @biomejs/biome check src/",
    "lint:fix": "bunx --bun @biomejs/biome check --write src/",
    "format": "bunx --bun @biomejs/biome format --write src/",
    "check": "bun run lint && bun run build && bun run test",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai",
    "enablement",
    "assessment",
    "copilot",
    "repository",
    "analysis",
    "adr",
    "architecture",
    "readiness"
  ],
  "author": "Ankh Studio",
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "0.1.32",
    "@specfy/stack-analyser": "^1.27.6",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "ora": "^5.4.1",
    "semver": "^7.5.0",
    "simple-git": "^3.33.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ankh-Studio/ai-enablement-platform.git"
  },
  "homepage": "https://github.com/Ankh-Studio/ai-enablement-platform#readme",
  "bugs": {
    "url": "https://github.com/Ankh-Studio/ai-enablement-platform/issues"
  }
}
