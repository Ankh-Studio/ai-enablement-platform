# Copilot SDK Configuration
COPILOT_ENABLED=true
COPILOT_GITHUB_TOKEN=your_github_token_here
COPILOT_USE_LOGGED_IN_USER=false

# Copilot Model Settings
COPILOT_MODEL=gpt-4
COPILOT_REASONING_EFFORT=low
COPILOT_TIMEOUT_MS=325
COPILOT_LOG_LEVEL=error
COPILOT_CLIENT_NAME=ai-enable-platform

# Copilot Runtime Configuration
COPILOT_CLI_PATH=
COPILOT_CLI_URL=
COPILOT_WORKING_DIRECTORY=
COPILOT_CONFIG_DIR=.copilot-sdk

# Copilot Telemetry (Optional)
COPILOT_OTLP_ENDPOINT=
COPILOT_TELEMETRY_EXPORTER=otlp-http
COPILOT_TELEMETRY_FILE_PATH=
COPILOT_TELEMETRY_SOURCE_NAME=ai-enable-platform
COPILOT_TELEMETRY_CAPTURE_CONTENT=false
